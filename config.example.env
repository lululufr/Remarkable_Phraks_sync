# Copier en `phraks.env` et adapter. Toutes les variables sont optionnelles.

# Dossier de destination sur la reMarkable (cloud). Défaut : CYBER/PHRAKS
#PHRAKS_RM_DIR=CYBER/PHRAKS

# Fichier d'état mémorisant le dernier numéro traité.
#PHRAKS_STATE_FILE=/home/lucas/Documents/PHRAKS_AUTO/state/last_issue.txt

# Chemin du binaire rmapi si pas dans le PATH.
#PHRAKS_RMAPI=/usr/local/bin/rmapi
